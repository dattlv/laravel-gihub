### Không tốt - Tự triển khai khi đã có package sẵn

```jsx
// Tự triển khai data grid thay vì sử dụng @mui/x-data-grid
import { Table, TableBody, TableCell, TableContainer, TableHead, TableRow, Paper } from '@mui/material';

function CustomDataGrid({ rows, columns }) {
  return (
    <TableContainer component={Paper}>
      <Table>
        <TableHead>
          <TableRow>
            {columns.map((column) => (
              <TableCell key={column.field}>{column.headerName}</TableCell>
            ))}
          </TableRow>
        </TableHead>
        <TableBody>
          {rows.map((row) => (
            <TableRow key={row.id}>
              {columns.map((column) => (
                <TableCell key={`${row.id}-${column.field}`}>{row[column.field]}</TableCell>
              ))}
            </TableRow>
          ))}
        </TableBody>
      </Table>
    </TableContainer>
  );
}
```

### Không tốt - Sử dụng npm thay vì yarn

```bash
# Sử dụng npm thay vì yarn
npm install @mui/material

# Dùng npm với các lệnh không chuẩn
npm i redux
```

### Không tốt - Sử dụng TypeScript

```tsx
// Sử dụng TypeScript thay vì JavaScript
import React, { FC, useState } from 'react';
import { Button } from '@mui/material';

interface CounterProps {
  initialValue: number;
}

const Counter: FC<CounterProps> = ({ initialValue }) => {
  const [count, setCount] = useState<number>(initialValue);
  
  return (
    <div>
      <p>{count}</p>
      <Button onClick={() => setCount(count + 1)}>Increment</Button>
    </div>
  );
};

export default Counter;
```
</example>
